# =============================================================
# CONVEX SETUP
# =============================================================
# 1. Jalankan: npx convex dev
#    (login dengan akun Convex / GitHub kalau pertama kali)
# 2. Convex CLI akan otomatis membuat file .env.local
#    dan mengisi VITE_CONVEX_URL untuk kamu.
# 3. Biarkan terminal `npx convex dev` tetap berjalan saat development
#    agar perubahan di folder convex/ ter-deploy otomatis.
#
# Kalau mau isi manual, copy file ini jadi .env dan ganti URL di bawah:
VITE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
